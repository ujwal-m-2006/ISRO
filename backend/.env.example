# Copy this file to .env and fill in real values — .env is gitignored and never committed.

# PRADAN (ISRO Aditya-L1 archive) — pradan1.issdc.gov.in
# Register a free account at https://pradan1.issdc.gov.in/al1/ first.
PRADAN_USERNAME=
PRADAN_PASSWORD=

# NASA DONKI (CME data) — optional, defaults to the shared DEMO_KEY (30 req/hr).
# Get a free key instantly at https://api.nasa.gov/#signUp
NASA_API_KEY=

# Supabase (prediction accuracy tracking persistence)
# Project settings -> API on your Supabase dashboard.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# service_role key — required for backend writes (bypasses RLS). Keep secret, server-side only.
SUPABASE_SERVICE_ROLE_KEY=

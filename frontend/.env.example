# Copy to .env.local for local overrides, or set in Vercel's project
# settings (Settings -> Environment Variables) for production.

# Where the backend API actually lives. Leave empty for local dev (Vite's
# proxy in vite.config.ts handles /api -> localhost:8000 automatically).
# In production, set this to your deployed backend's real URL, e.g.:
#   VITE_API_BASE_URL=https://your-backend.example.com
VITE_API_BASE_URL=
